---
import Layout from '../layouts/Layout.astro';
import Scanner from '../components/Scanner.vue';
---

<Layout title="Pharos AI | Job Fraud Shield & Cover Letter Generator">
	<div class="flex flex-col items-center justify-center text-center max-w-4xl mx-auto space-y-8 my-10 relative">
		<div class="absolute top-[-50px] w-72 h-72 bg-brand-primary/20 rounded-full blur-[100px] pointer-events-none"></div>

		<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-gradient-start text-xs font-semibold uppercase tracking-wider">
			<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
				<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
			</svg>
			Next-Gen AI Security
		</div>

		<h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight leading-tight max-w-3xl">
			Protect Your Career from <span class="text-gradient">Job Scams</span>
		</h1>

		<p class="text-text-secondary text-base sm:text-lg max-w-2xl leading-relaxed">
			Instantly analyze job vacancies for fraud signals, security risks, and redirection traps. If it's safe, leverage elite AI to craft a customized, highly persuasive cover letter matching your resume in seconds.
		</p>
	</div>

	<div class="w-full mt-6 relative z-10">
		<Scanner client:load />
	</div>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto mt-20">
		<div class="glass-panel p-6 space-y-3">
			<div class="w-10 h-10 rounded-lg bg-brand-primary/10 border border-brand-primary/25 flex items-center justify-center text-brand-gradient-start">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
				</svg>
			</div>
			<h3 class="font-bold text-lg">Anti-Fraud Shield</h3>
			<p class="text-sm text-text-secondary leading-relaxed">
				Uses advanced semantic scanning to flag suspicious external redirections, telegram payouts, or financial traps.
			</p>
		</div>

		<div class="glass-panel p-6 space-y-3">
			<div class="w-10 h-10 rounded-lg bg-brand-primary/10 border border-brand-primary/25 flex items-center justify-center text-brand-gradient-start">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
					<polyline points="14 2 14 8 20 8"/>
					<line x1="16" y1="13" x2="8" y2="13"/>
					<line x1="16" y1="17" x2="8" y2="17"/>
					<polyline points="10 9 9 9 8 9"/>
				</svg>
			</div>
			<h3 class="font-bold text-lg">Resume Alignment</h3>
			<p class="text-sm text-text-secondary leading-relaxed">
				Dials in your professional profile and highlights your actual achievements, matching them with the job listing seamlessly.
			</p>
		</div>

		<div class="glass-panel p-6 space-y-3">
			<div class="w-10 h-10 rounded-lg bg-brand-primary/10 border border-brand-primary/25 flex items-center justify-center text-brand-gradient-start">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polygon points="12 2 2 22 22 22"/>
					<line x1="12" y1="9" x2="12" y2="13"/>
					<line x1="12" y1="17" x2="12.01" y2="17"/>
				</svg>
			</div>
			<h3 class="font-bold text-lg">Multimodal Scan</h3>
			<p class="text-sm text-text-secondary leading-relaxed">
				Drag and drop screenshot images, job PDFs, or copy-pasted details. Gemini handles visual analysis natively.
			</p>
		</div>
	</div>
</Layout>
